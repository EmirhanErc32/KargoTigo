

# --- Sunucu ---
PORT=3000
# Frontend'in calistigi adres (CORS icin). Birden fazlaysa virgulle ayirin.
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# --- JWT (Token) Ayarlari ---
# Guclu, rastgele bir deger girin. Ornek uretmek icin:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=buraya_cok_gizli_rastgele_bir_anahtar_girin
JWT_EXPIRES_IN=2h

# --- Supabase ---
# Supabase proje panelinden alin: Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Frontend icin (anon key - RLS ile korunur)
SUPABASE_ANON_KEY=eyJhbGciOi...
# DIKKAT: service_role anahtari sadece BACKEND'de kullanilir, asla frontend'e koymayin!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- AI Analizi (n8n onerilir) ---
AI_PROVIDER=n8n
N8N_WEBHOOK_URL=https://SENIN-ALANIN.app.n8n.cloud/webhook/kargo-analiz
# Opsiyonel webhook guvenligi:
# N8N_WEBHOOK_AUTH_HEADER=x-webhook-secret
# N8N_WEBHOOK_AUTH_VALUE=belirledigin-gizli-deger

# --- Google Gemini (AI_PROVIDER=gemini ise) ---
# https://aistudio.google.com/app/apikey adresinden ucretsiz alabilirsiniz.
GEMINI_API_KEY=AIzaSy...
# Kullanilacak model (gorsel + Google arama destekli)
GEMINI_MODEL=gemini-2.5-flash

# --- Kargo / Tasima API'si (Opsiyonel) ---
# Gercek bir kargo API'niz varsa buraya girin. Bos birakilirsa
# yerlesik gercekci hesaplama motoru (formul) kullanilir.
SHIPPING_PROVIDER=internal
SHIPPING_API_URL=
SHIPPING_API_KEY=
